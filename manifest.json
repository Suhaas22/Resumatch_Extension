{
  "manifest_version": 3,
  "name": "ResuMatch — Resume Analyzer",
  "version": "1.0",
  "description": "Instantly analyze your resume against any job on LinkedIn or Naukri.",

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://www.naukri.com/*"
      ],
      "js": ["content.js"]
    }
  ],

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.naukri.com/*",
    "https://resumatch-backend-hbfn.onrender.com/*"
  ]
}
